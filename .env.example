# eisy device connection (auto-discovered on dev startup, but can be set manually)
VITE_EISY_HOST=192.168.4.123
VITE_EISY_PORT=8443
VITE_EISY_PROTOCOL=https
VITE_EISY_USER=admin
VITE_EISY_PASS=admin

# GitHub Personal Access Token for issue reporting
# Create a fine-grained PAT at: https://github.com/settings/tokens?type=beta
# Required permissions: Issues (Read & Write)
# Users can also set this in Settings > About > GitHub Integration
VITE_GITHUB_PAT=
